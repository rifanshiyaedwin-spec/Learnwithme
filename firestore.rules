rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Validation Blueprint for UserProgress
    function isValidUserProgress(data) {
      return data.keys().hasAll(['userId', 'language', 'level', 'currentLesson', 'percentage', 'updatedAt']) 
          && data.keys().size() >= 6
          && data.keys().size() <= 8
          && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
          && data.language is string && data.language.size() <= 100
          && data.level is string && data.level.size() <= 100
          && data.currentLesson is number
          && data.percentage is number
          && data.get('assessmentScore', 0) is number
          && data.get('hasCertificate', false) is bool
          && (data.updatedAt == request.time || data.updatedAt is timestamp);
    }

    // Rules for User Progress Subcollection
    // users/{userId}/progress/{progressId}
    match /users/{userId}/progress/{progressId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() 
                    && request.auth.uid == userId
                    && isValidId(progressId)
                    && isValidUserProgress(incoming())
                    && incoming().updatedAt == request.time;
      
      allow update: if isSignedIn() 
                    && request.auth.uid == userId
                    && isValidUserProgress(incoming())
                    && incoming().userId == existing().userId
                    && incoming().language == existing().language
                    && incoming().level == existing().level
                    && incoming().updatedAt == request.time
                    && incoming().diff(existing()).affectedKeys().hasOnly(['currentLesson', 'percentage', 'assessmentScore', 'hasCertificate', 'updatedAt']);
                    
      allow delete: if isSignedIn() && request.auth.uid == userId; // Allow user to cancel enrollment
      allow list: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
